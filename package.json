{
  "name": "mcp-agent-messenger",
  "version": "2.0.0",
  "description": "MCP server for agent-to-agent and agent-to-group messaging",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "mcp-agent-messenger": "dist/src/index.js"
  },
  "scripts": {
    "build": "npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsc --watch -p tsconfig.json",
    "test": "npm run build:server && node --test dist/tests/**/*.test.js"
  },
  "keywords": [
    "mcp",
    "agent",
    "communication",
    "cursor"
  ],
  "author": "Binyamin Eden",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BinyaminEden/agent-messenger.git"
  },
  "bugs": {
    "url": "https://github.com/BinyaminEden/agent-messenger/issues"
  },
  "homepage": "https://github.com/BinyaminEden/agent-messenger#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
